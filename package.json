{
  "name": "project-tracker-electron",
  "version": "0.1.0",
  "description": "Native macOS Project Tracker desktop app",
  "author": "Project Tracker",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "dist": "bun run build && electron-builder --mac",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "electron-is-dev": "^3.0.1",
    "pinia": "^2.3.1",
    "sql.js": "^1.13.0",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/sql.js": "^1.4.9",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.2",
    "vue-tsc": "^2.2.10",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.projecttracker.desktop",
    "productName": "Project Tracker",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/app-icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "assets/app-icon.png",
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "icon": "assets/app-icon.png",
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  }
}
